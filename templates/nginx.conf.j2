# Generated by swiftdeploy — do not edit manually
# Source of truth: manifest.yaml

log_format swiftdeploy '$time_iso8601 | $status | ${request_time}s | $upstream_addr | $request';

# ── HTTP server — redirects all traffic to HTTPS ───────────────────────────
server {
    listen 80;
    server_name {{ domain }};

    # Redirect every HTTP request to the HTTPS equivalent
    # 301 = permanent redirect — browsers remember this
    # WHY: we never want unencrypted traffic reaching the app
    return 301 https://$host$request_uri;
}

# ── HTTPS server — main server block ──────────────────────────────────────
server {
    listen 443 ssl;
    server_name {{ domain }};

    access_log /var/log/nginx/access.log swiftdeploy;
    error_log  /var/log/nginx/error.log warn;

    # SSL certificate files — mounted into the container from host
    ssl_certificate     {{ ssl_cert }};
    ssl_certificate_key {{ ssl_key }};

    # Modern SSL settings — disables old insecure protocol versions
    # TLSv1.2 and TLSv1.3 are the only versions considered secure today
    ssl_protocols TLSv1.2 TLSv1.3;

    # Prefer strong cipher suites — controls how the encryption handshake works
    ssl_ciphers HIGH:!aNULL:!MD5;
    ssl_prefer_server_ciphers on;

    # SSL session caching — speeds up repeat connections
    # WHY: without this every request does a full SSL handshake (slow)
    ssl_session_cache shared:SSL:10m;
    ssl_session_timeout 10m;

    # HSTS — tells browsers to always use HTTPS for this domain
    # max-age=31536000 = remember this for one year
    # WHY: prevents downgrade attacks where someone forces HTTP
    add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;

    # Proxy timeouts — read from manifest via proxy_timeout field
    # Resolver for upstream DNS — uses Docker's internal DNS
    # 127.0.0.11 is Docker's built-in DNS resolver
    resolver 127.0.0.11 valid=10s;
    resolver_timeout 5s;
    proxy_connect_timeout {{ proxy_timeout }}s;
    proxy_send_timeout    {{ proxy_timeout }}s;
    proxy_read_timeout    {{ proxy_timeout }}s;

    # Stamp every response so you know swiftdeploy served it
    add_header X-Deployed-By swiftdeploy always;

    # Forward the X-Mode header from the app upstream
    # WHY: canary mode sets X-Mode: canary — Nginx must not strip it
    proxy_pass_header X-Mode;

    location / {
        proxy_pass http://app:{{ service_port }};

        # Tell the app who the real client is
        # Without these the app sees Nginx's IP for every request
        proxy_set_header Host              $host;
        proxy_set_header X-Real-IP         $remote_addr;
        proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # JSON error bodies — never expose raw Nginx HTML error pages
    error_page 502 = @error502;
    error_page 503 = @error503;
    error_page 504 = @error504;

    location @error502 {
        default_type application/json;
        add_header X-Deployed-By swiftdeploy always;
        return 502 '{"error":"Bad Gateway","code":502,"service":"app","contact":"ops@swiftdeploy.local"}';
    }
    location @error503 {
        default_type application/json;
        add_header X-Deployed-By swiftdeploy always;
        return 503 '{"error":"Service Unavailable","code":503,"service":"app","contact":"ops@swiftdeploy.local"}';
    }
    location @error504 {
        default_type application/json;
        add_header X-Deployed-By swiftdeploy always;
        return 504 '{"error":"Gateway Timeout","code":504,"service":"app","contact":"ops@swiftdeploy.local"}';
    }
}
