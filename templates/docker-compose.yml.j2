# Generated by swiftdeploy — do not edit manually
# Source of truth: manifest.yaml

networks:
  {{ network_name }}:
    driver: {{ network_driver }}

volumes:
  {{ log_volume }}:

services:
  app:
    image: {{ service_image }}
    container_name: swiftdeploy-app
    restart: {{ restart_policy }}
    environment:
      - MODE={{ mode }}
      - APP_VERSION={{ app_version }}
      - APP_PORT={{ service_port }}
    networks:
      - {{ network_name }}
    volumes:
      - {{ log_volume }}:/app/logs
    expose:
      - "{{ service_port }}"
    # Security hardening — drop all Linux capabilities
    # then add back only what the app needs
    cap_drop:
      - ALL
    cap_add:
      - NET_BIND_SERVICE
    security_opt:
      - no-new-privileges:true
    user: "appuser"
    healthcheck:
      test: ["CMD", "python", "-c", "import urllib.request; urllib.request.urlopen('http://localhost:{{ service_port }}/healthz')"]
      interval: 10s
      timeout: 5s
      retries: 6
      start_period: 10s

  nginx:
    image: {{ nginx_image }}
    container_name: swiftdeploy-nginx
    restart: {{ restart_policy }}
    ports:
      - "80:80"
      - "443:443"
    networks:
      - {{ network_name }}
    volumes:
      # Generated nginx config — read only so nothing inside can modify it
      - ./nginx.conf:/etc/nginx/conf.d/default.conf:ro
      # SSL certificates — mounted from host certs/ folder
      - ./certs/fullchain.pem:/etc/nginx/certs/fullchain.pem:ro
      - ./certs/privkey.pem:/etc/nginx/certs/privkey.pem:ro
      # Nginx logs volume — persists across container restarts
      - {{ log_volume }}:/var/log/nginx
    depends_on:
      app:
        condition: service_healthy
